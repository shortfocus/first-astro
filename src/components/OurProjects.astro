---
import { siteConfig } from "@/config/site.config";

const projects = siteConfig.projects;
const carouselItems = siteConfig.portfolioPage.projects.slice(0, 5);
---

<section id="projects" class="border-t border-slate-800 bg-[#0d0d0d] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
      <!-- 좌측: 섹션 헤더 + 설명 -->
      <div>
        <span class="inline-flex rounded-lg bg-[#f43f5e] px-2.5 py-1 text-sm font-medium text-white">
          {projects.sectionLabel}
        </span>
        <h2 class="mt-4 text-3xl font-bold text-white md:text-4xl">
          {projects.title}
        </h2>
        <p class="mt-4 text-slate-300 leading-relaxed">
          {projects.descriptionLines[0]}<br />
          {projects.descriptionLines[1]}
        </p>
      </div>

      <!-- 우측: 프로젝트 캐러셀 -->
      <div class="projects-carousel relative">
        <!-- 카드 스택 (앞 카드 + 뒤 카드) -->
        <div class="relative min-h-[320px] md:min-h-[380px]">
          {carouselItems.map((item, index) => (
            <div
              class="projects-slide absolute inset-0 flex justify-center transition-opacity duration-300"
              data-index={index}
              style={index === 0 ? "opacity: 1; z-index: 2;" : "opacity: 0; z-index: 1; pointer-events: none;"}
            >
              <!-- 디바이스 목업 카드 (살짝 기울임) -->
              <div
                class="w-full max-w-md rounded-2xl border border-slate-700 bg-slate-800/90 p-4 shadow-xl transition-transform"
                style="transform: rotate(-2deg);"
              >
                <!-- 노트북/디바이스 영역 플레이스홀더 -->
                <div class="aspect-video w-full overflow-hidden rounded-lg bg-slate-900">
                  {item.image ? (
                    <img src={item.image} alt="" class="h-full w-full object-cover" />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800">
                      <span class="text-sm text-slate-500">{item.title}</span>
                    </div>
                  )}
                </div>
                <!-- 카드 내부 오버레이: 제목 + 설명 -->
                <div class="mt-4">
                  <h3 class="text-lg font-bold text-white">{item.title}</h3>
                  <p class="mt-1 line-clamp-3 text-sm text-slate-400 leading-relaxed">
                    {item.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
          <!-- 뒤쪽에 보이는 두 번째 카드 -->
          {carouselItems[1] && (
            <div
              class="absolute right-0 top-4 w-[85%] max-w-sm rounded-2xl border border-slate-600 bg-slate-800/70 p-3 shadow-lg"
              style="transform: rotate(3deg); z-index: 0;"
              aria-hidden="true"
            >
              <div class="aspect-video rounded-lg bg-slate-900"></div>
              <p class="mt-2 line-clamp-2 text-xs text-slate-500">{carouselItems[1].title}</p>
            </div>
          )}
        </div>

        <!-- 큰 프로젝트 제목 -->
        <p class="projects-big-title mt-8 text-center text-2xl font-bold text-white md:text-3xl" data-current-title={carouselItems[0]?.title}>
          {carouselItems[0]?.title}
        </p>

        <!-- 페이지네이션 dots -->
        <div class="mt-4 flex justify-center gap-2" role="tablist" aria-label="프로젝트 선택">
          {carouselItems.map((_, index) => (
            <button
              type="button"
              class="projects-dot h-2 w-2 rounded-full transition-colors"
              data-index={index}
              data-active={index === 0}
              role="tab"
              aria-label={`프로젝트 ${index + 1}`}
              aria-selected={index === 0}
            >
            </button>
          ))}
        </div>

        <!-- 프로젝트 더보기 버튼 -->
        <div class="mt-8 flex justify-center">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-1 rounded-lg border-2 border-white bg-transparent px-6 py-3 text-sm font-medium text-white transition hover:bg-white hover:text-slate-900"
          >
            {projects.viewMoreLabel}
            <span aria-hidden="true">&gt;</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .projects-dot[data-active="true"] {
    background-color: rgb(248 250 252);
    width: 0.5rem;
    height: 0.5rem;
  }
  .projects-dot[data-active="false"] {
    background-color: rgb(51 65 85);
    width: 0.5rem;
    height: 0.5rem;
  }
</style>

<script is:inline>
  (function () {
    var wrap = document.querySelector(".projects-carousel");
    if (!wrap) return;
    var slides = wrap.querySelectorAll(".projects-slide");
    var bigTitle = wrap.querySelector(".projects-big-title");
    var dots = wrap.querySelectorAll(".projects-dot");
    var titles = [];
    slides.forEach(function (s) {
      var card = s.querySelector("h3");
      titles.push(card ? card.textContent : "");
    });

    function goTo(index) {
      if (index < 0 || index >= slides.length) return;
      slides.forEach(function (s, i) {
        s.style.opacity = i === index ? "1" : "0";
        s.style.zIndex = i === index ? "2" : "1";
        s.style.pointerEvents = i === index ? "auto" : "none";
      });
      dots.forEach(function (d, i) {
        d.setAttribute("data-active", i === index ? "true" : "false");
        d.setAttribute("aria-selected", i === index ? "true" : "false");
      });
      if (bigTitle && titles[index]) {
        bigTitle.textContent = titles[index];
        bigTitle.setAttribute("data-current-title", titles[index]);
      }
    }

    dots.forEach(function (dot, index) {
      dot.addEventListener("click", function () {
        goTo(index);
      });
    });
  })();
</script>
