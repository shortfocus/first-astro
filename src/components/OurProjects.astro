---
import { siteConfig } from "@/config/site.config";

const projects = siteConfig.projects;
const showcaseItems = siteConfig.portfolioPage.projects.slice(0, 6);
---

<section id="projects" class="border-t border-slate-800 bg-[#0d0d0d] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- 01, 02와 동일한 헤더 블록 -->
    <div class="rounded-2xl border border-slate-800 border-l-4 border-l-[#f43f5e] bg-slate-900/20 px-6 py-5">
      <h2 class="text-2xl font-bold text-white md:text-3xl">
        <span class="text-[#f43f5e]">{projects.sectionLabel}</span> {projects.title}
      </h2>
      <p class="mt-3 text-slate-400">
        {projects.descriptionLines[0]} {projects.descriptionLines[1]}
      </p>
    </div>

    <!-- 직사각형 카드 그리드 (01 What We Do와 동일한 카드 스타일) -->
    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {showcaseItems.map((item) => (
        <a
          href={item.link}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col overflow-hidden rounded-2xl border border-slate-800 border-t-[#f43f5e]/50 bg-slate-900/30 transition hover:border-slate-700"
        >
          <div class="h-40 w-full shrink-0 overflow-hidden bg-slate-800">
            {item.image ? (
              <img src={item.image} alt="" class="h-full w-full object-cover object-center" />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-700 to-slate-800 text-slate-500">
                <span class="text-sm">{item.title}</span>
              </div>
            )}
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h3 class="text-lg font-bold text-white">{item.title}</h3>
            {item.description ? (
              <p class="mt-2 line-clamp-2 text-sm text-slate-400 leading-relaxed">{item.description}</p>
            ) : (
              <div class="mt-2 flex-1" />
            )}
            <span class="mt-4 inline-flex items-center text-sm font-medium text-[#f43f5e]">
              {projects.viewMoreLabel}
              <span aria-hidden="true">&rarr;</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <a
        href="/portfolio"
        class="inline-flex items-center gap-1 rounded-lg border-2 border-white bg-transparent px-6 py-3 text-sm font-medium text-white transition hover:bg-white hover:text-slate-900"
      >
        {projects.viewMoreLabel}
        <span aria-hidden="true">&gt;</span>
      </a>
    </div>
  </div>
</section>
