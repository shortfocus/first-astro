---
import { siteConfig } from "@/config/site.config";

const pathname = Astro.url.pathname;
const navItems = siteConfig.nav.items ?? [
  { label: siteConfig.name, href: "/" },
  { label: "포트폴리오", href: "/portfolio" },
  { label: siteConfig.nav.consult, href: "/contact" },
  { label: "스타트업 트랙", href: "#startup-track" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/" || pathname === "";
  if (href.startsWith("#")) return false;
  return pathname === href || pathname === href + "/";
}
---

<header class="theme-header sticky top-0 z-50 border-b border-slate-800 bg-[#0D0D0D]">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="font-logo text-xl font-bold text-white sm:text-2xl theme-logo">
      {siteConfig.name}
    </a>

    <div class="flex items-center gap-4">
    <!-- 언더라인 네비 -->
    <nav class="nav-underline hidden md:flex md:items-center md:gap-8" aria-label="메인 메뉴">
      {navItems.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              "nav-link border-b-2 pb-1 text-sm font-medium transition-colors",
              active
                ? "border-white text-white"
                : "border-transparent text-slate-400 hover:border-white/40 hover:text-white",
            ]}
            data-href={item.href}
            aria-current={active ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- 모바일: 햄버거 -->
    <div class="flex items-center gap-3 md:hidden">
      <button
        type="button"
        class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded border border-slate-600 bg-transparent text-slate-400"
        aria-label="메뉴 열기"
        id="menu-toggle"
      >
        <span class="h-0.5 w-5 bg-current"></span>
        <span class="h-0.5 w-5 bg-current"></span>
        <span class="h-0.5 w-5 bg-current"></span>
      </button>
    </div>
    </div>
  </div>

  <!-- 모바일 메뉴 -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-800 bg-[#0D0D0D] px-6 py-4 md:hidden"
  >
    <nav class="flex flex-col gap-1 text-sm">
      {navItems.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              "nav-link border-l-2 py-2.5 pl-4 font-medium transition-colors",
              active ? "border-white text-white" : "border-transparent text-slate-400 hover:border-white/50 hover:text-white",
            ]}
            data-href={item.href}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => menu.classList.toggle("hidden"));
  }

  function setActiveNav() {
    const pathname = window.location.pathname || "/";
    const hash = window.location.hash || "";
    document.querySelectorAll(".nav-link").forEach((el) => {
      const link = el as HTMLAnchorElement;
      const href = link.getAttribute("data-href") || "";
      const isPath = href.startsWith("/") && !href.startsWith("//");
      const isActive = isPath
        ? (pathname === href || pathname === href + "/")
        : (hash === "" ? href === "/" : href === hash);
      link.classList.toggle("border-white", isActive);
      link.classList.toggle("border-transparent", !isActive);
      link.classList.toggle("text-white", isActive);
      link.classList.toggle("text-slate-400", !isActive);
      link.setAttribute("aria-current", isActive ? "page" : "false");
    });
  }
  setActiveNav();
  window.addEventListener("hashchange", setActiveNav);
  window.addEventListener("popstate", setActiveNav);
</script>
