---
import { siteConfig } from "@/config/site.config";
---

<section id="what-we-do" class="border-t border-slate-800 bg-[#0d0d0d] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-2xl border border-slate-800 border-l-4 border-l-[#f43f5e] bg-slate-900/20 px-6 py-5">
      <h2 class="text-2xl font-bold text-white md:text-3xl">
        <span class="text-[#f43f5e]">01</span> What We Do
      </h2>
      <p class="mt-3 text-slate-400">
        {siteConfig.whatWeDo.subtitle}
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        siteConfig.whatWeDo.items.map((item) => (
          <div class="rounded-2xl border border-slate-800 border-t-[#f43f5e]/50 bg-slate-900/30 p-6">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#f43f5e]/40 bg-[#f43f5e] text-sm font-bold text-white">
              {item.number}
            </div>
            <h3 class="mt-6 text-xl font-bold text-white">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              {item.description}
            </p>
            <ul class="mt-4 space-y-2 text-sm text-slate-500">
              {item.list.map((li) => (
                <li>· {li}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
