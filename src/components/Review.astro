---
import { siteConfig } from "@/config/site.config";
---

<section id="review" class="border-t border-slate-800 bg-[#0d0d0d] py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-2xl border border-slate-800 border-l-4 border-l-[#f43f5e] bg-slate-900/20 px-6 py-5">
      <h2 class="text-2xl font-bold text-white md:text-3xl">
        <span class="text-[#f43f5e]">04</span> Review
      </h2>
      <p class="mt-3 text-slate-400">
        {siteConfig.review.subtitle}
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        siteConfig.review.items.map((r) => (
          <div class="rounded-2xl border border-slate-800 border-l-[#f43f5e]/50 bg-slate-900/30 p-6">
            <p class="text-slate-300">"{r.quote}"</p>
            <p class="mt-4 text-sm text-slate-500">— {r.author}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
