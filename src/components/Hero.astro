---
import { siteConfig } from "@/config/site.config";
import HeroCanvas from "@/components/HeroCanvas";
import HeroCtaButton from "@/components/HeroCtaButton";
---

<section class="relative overflow-hidden bg-[#0d0d0d]">
  <div class="mx-auto max-w-6xl px-4 pt-16 pb-8 sm:px-6 sm:pt-20 sm:pb-10 md:pt-28 md:pb-14">
    <div class="mb-10 sm:mb-14 md:mb-20">
      <h1 class="text-2xl font-bold leading-[1.25] tracking-tight text-white sm:text-4xl sm:leading-[1.2] md:text-5xl md:tracking-[-0.02em]">
        {siteConfig.hero.title}
      </h1>
      <p class="mt-6 max-w-[65ch] text-[15px] font-bold leading-relaxed text-slate-400 sm:mt-8 sm:text-base sm:leading-relaxed md:max-w-none md:text-lg">
        {siteConfig.hero.subtitleMain}
        <br />
        <span class="inline md:whitespace-nowrap">{siteConfig.hero.subtitleEnd}</span>
      </p>
      {siteConfig.hero.support && (
        <p class="mt-4 text-xs text-slate-500 sm:mt-5 sm:text-sm">
          {siteConfig.hero.support}
        </p>
      )}
      <HeroCtaButton client:load href="#contact">
        {siteConfig.hero.ctaText}
      </HeroCtaButton>
    </div>

    <div class="relative w-full">
      <div class="relative flex min-h-[18rem] w-full items-center justify-center rounded-xl border border-white/[0.08] bg-[#0d0d0d] sm:min-h-[22rem] sm:rounded-2xl md:min-h-[28rem]">
        <div class="absolute inset-0 overflow-hidden rounded-xl sm:rounded-2xl">
          <HeroCanvas client:load />
        </div>
        <span class="font-logo relative z-10 text-2xl font-normal tracking-tight text-white sm:text-3xl md:text-5xl md:tracking-[-0.02em] drop-shadow-sm">
          {siteConfig.name}
        </span>
      </div>
    </div>
  </div>
</section>
